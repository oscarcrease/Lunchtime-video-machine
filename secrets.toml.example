# Copy this file to .streamlit/secrets.toml for LOCAL development.
# .streamlit/secrets.toml is gitignored and never committed.
#
# For DEPLOYED use on Streamlit Community Cloud, you don't create this
# file at all -- instead paste the same contents into your app's
# Settings -> Secrets box in the Community Cloud dashboard.

[google_oauth]
client_id = "your-client-id.apps.googleusercontent.com"
client_secret = "your-client-secret"

# LOCAL dev: http://localhost:8501
# DEPLOYED: https://your-app-name.streamlit.app
redirect_uri = "http://localhost:8501"

# Leave this out entirely at first. After your first login, the sidebar
# will show you a refresh_token to paste in here -- that's what lets the
# app log you in silently on future visits/reboots without you having to
# click through Google's consent screen every time.
# refresh_token = "paste-the-token-shown-after-first-login-here"

[turso]
# From your Turso database dashboard/CLI. Leave this whole [turso]
# section out entirely for local dev if you don't want to bother with a
# Turso account yet -- the app falls back to a local SQLite file
# automatically. You DO need this configured for the deployed app,
# though, or watched history/subscriptions will reset on every reboot.
database_url = "libsql://your-database-name.turso.io"
auth_token = "your-turso-auth-token"
